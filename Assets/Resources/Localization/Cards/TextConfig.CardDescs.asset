  - id: card_0013_desc
    textList:
    - language: 0
      text: Deal {{DMG}} damage. Reduce enemy Action Gauge by 20%.
    - language: 1
      text: "G\xE2y {{DMG}} s\xE1t th\u01B0\u01A1ng v\xE0 gi\u1EA3m 20% Thanh H\xE0nh
