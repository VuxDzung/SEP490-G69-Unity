  - id: card_0011_desc
    textList:
    - language: 0
      text: Deal {{DMG}} damage.
    - language: 1
      text: "G\xE2y {{DMG}} s\xE1t th\u01B0\u01A1ng."
  - id: card_0012_desc
    textList:
    - language: 0
