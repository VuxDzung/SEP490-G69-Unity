%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01c2cf2a4b2c62142a7668242814b230, type: 3}
  m_Name: TextConfig.ItemDescs
  m_EditorClassIdentifier: 
  category: ItemDescs
  textDataList:
  - id: itm_0001
    textList:
    - language: 0
      text: A simple drink that restores a small amount of energy
    - language: 1
      text: "M\u1ED9t th\u1EE9c u\u1ED1ng \u0111\u01A1n gi\u1EA3n gi\xFAp h\u1ED3i
        m\u1ED9t l\u01B0\u1EE3ng nh\u1ECF n\u0103ng l\u01B0\u1EE3ng"
  - id: itm_0002
    textList:
    - language: 0
      text: A nutritious academy meal that restores a moderate amount of energy
    - language: 1
      text: "M\u1ED9t b\u1EEFa \u0103n dinh d\u01B0\u1EE1ng t\u1EA1i h\u1ECDc vi\u1EC7n
        gi\xFAp h\u1ED3i m\u1ED9t l\u01B0\u1EE3ng n\u0103ng l\u01B0\u1EE3ng v\u1EEBa
        ph\u1EA3i"
  - id: itm_0003
    textList:
    - language: 0
      text: A powerful stimulant that restores a large amount of energy but lowers
        mood
    - language: 1
      text: "M\u1ED9t ch\u1EA5t k\xEDch th\xEDch m\u1EA1nh gi\xFAp h\u1ED3i ph\u1EE5c
        l\u01B0\u1EE3ng l\u1EDBn n\u0103ng l\u01B0\u1EE3ng nh\u01B0ng l\xE0m gi\u1EA3m
        t\xE2m tr\u1EA1ng"
  - id: itm_0005
    textList:
    - language: 0
      text: A recovery chip that restores energy and slightly improves mood
    - language: 1
      text: "M\u1ED9t con chip ph\u1EE5c h\u1ED3i gi\xFAp h\u1ED3i n\u0103ng l\u01B0\u1EE3ng
        v\xE0 c\u1EA3i thi\u1EC7n nh\u1EB9 t\xE2m tr\u1EA1ng"
  - id: itm_0006
    textList:
    - language: 0
      text: An inspiring poster that slightly boosts mood
    - language: 1
      text: "M\u1ED9t t\u1EA5m \xE1p ph\xEDch gi\xFAp t\u0103ng nh\u1EB9 t\xE2m tr\u1EA1ng"
  - id: itm_0007
    textList:
    - language: 0
      text: A heartfelt letter from a coach that significantly improves mood
    - language: 1
      text: "M\u1ED9t b\u1EE9c th\u01B0 ch\xE2n th\xE0nh gi\xFAp c\u1EA3i thi\u1EC7n
        \u0111\xE1ng k\u1EC3 t\xE2m tr\u1EA1ng"
  - id: itm_0008
    textList:
    - language: 0
      text: A mysterious charm that consumes energy to improve mood
    - language: 1
      text: "M\u1ED9t l\xE1 b\xF9a b\xED \u1EA9n ti\xEAu hao n\u0103ng l\u01B0\u1EE3ng
        \u0111\u1EC3 c\u1EA3i thi\u1EC7n t\xE2m tr\u1EA1ng"
  - id: itm_0009
    textList:
    - language: 0
      text: A deceptive praise recording that increases mood but slightly reduces
        intelligence
    - language: 1
      text: "M\u1ED9t \u0111o\u1EA1n ghi \xE2m l\u1EDDi khen gi\u1EA3 t\u1EA1o gi\xFAp
        t\u0103ng t\xE2m tr\u1EA1ng nh\u01B0ng gi\u1EA3m nh\u1EB9 tr\xED tu\u1EC7"
  - id: itm_0011
    textList:
    - language: 0
      text: A training manual that slightly increases strength
    - language: 1
      text: "M\u1ED9t t\xE0i li\u1EC7u hu\u1EA5n luy\u1EC7n gi\xFAp t\u0103ng nh\u1EB9
        s\u1EE9c m\u1EA1nh"
  - id: itm_0012
    textList:
    - language: 0
      text: An ancient scroll that slightly increases intelligence
    - language: 1
      text: "M\u1ED9t cu\u1ED9n th\u01B0 c\u1ED5 gi\xFAp t\u0103ng nh\u1EB9 tr\xED
        tu\u1EC7"
  - id: itm_0013
    textList:
    - language: 0
      text: A powerful injection that increases strength but significantly lowers
        mood
    - language: 1
      text: "M\u1ED9t m\u0169i ti\xEAm m\u1EA1nh m\u1EBD gi\xFAp t\u0103ng s\u1EE9c
        m\u1EA1nh nh\u01B0ng gi\u1EA3m m\u1EA1nh t\xE2m tr\u1EA1ng"
  - id: itm_0014
    textList:
    - language: 0
      text: A device that concentrates mental power to increase intelligence at the
        cost of energy
    - language: 1
      text: "M\u1ED9t thi\u1EBFt b\u1ECB d\u1ED3n n\xE9n s\u1EE9c m\u1EA1nh tinh
        th\u1EA7n \u0111\u1EC3 t\u0103ng tr\xED tu\u1EC7 nh\u01B0ng ti\xEAu hao n\u0103ng
        l\u01B0\u1EE3ng"
  - id: itm_0015
    textList:
    - language: 0
      text: A rare crystal that slightly increases all stats
    - language: 1
      text: "M\u1ED9t tinh th\u1EC3 hi\u1EBFm gi\xFAp t\u0103ng nh\u1EB9 t\u1EA5t
        c\u1EA3 ch\u1EC9 s\u1ED1"
  - id: itm_0016
    textList:
    - language: 0
      text: A stimulant that temporarily improves training effectiveness
    - language: 1
      text: "M\u1ED9t ch\u1EA5t k\xEDch th\xEDch gi\xFAp t\u1EA1m th\u1EDDi t\u0103ng
        hi\u1EC7u qu\u1EA3 hu\u1EA5n luy\u1EC7n"
  - id: itm_0017
    textList:
    - language: 0
      text: A mystical charm blessed by the zodiac that greatly boosts training effectiveness
    - language: 1
      text: "M\u1ED9t l\xE1 b\xF9a huy\u1EC1n b\xED \u0111\u01B0\u1EE3c ch\xF2m sao
        ban ph\xFAc, gi\xFAp t\u0103ng m\u1EA1nh hi\u1EC7u qu\u1EA3 hu\u1EA5n luy\u1EC7n"
  - id: itm_0018
    textList:
    - language: 0
      text: An aggressive training protocol that greatly increases training effectiveness
        but consumes energy
    - language: 1
      text: "M\u1ED9t ch\u1EBF \u0111\u1ED9 hu\u1EA5n luy\u1EC7n kh\u1EAFc nghi\u1EC7t
        gi\xFAp t\u0103ng m\u1EA1nh hi\u1EC7u qu\u1EA3 hu\u1EA5n luy\u1EC7n nh\u01B0ng
        ti\xEAu hao n\u0103ng l\u01B0\u1EE3ng"
  - id: itm_0019
    textList:
    - language: 0
      text: Forces the mind beyond its limits to boost training effectiveness but
        reduces mood
    - language: 1
      text: "\xC9p t\xE2m tr\xED v\u01B0\u1EE3t gi\u1EDBi h\u1EA1n \u0111\u1EC3 t\u0103ng
        hi\u1EC7u qu\u1EA3 hu\u1EA5n luy\u1EC7n nh\u01B0ng l\xE0m gi\u1EA3m t\xE2m
        tr\u1EA1ng"
  - id: itm_0020
    textList:
    - language: 0
      text: A carefully optimized planner that improves training efficiency and effectiveness
    - language: 1
      text: "M\u1ED9t k\u1EBF ho\u1EA1ch t\u1ED1i \u01B0u gi\xFAp c\u1EA3i thi\u1EC7n
        hi\u1EC7u su\u1EA5t v\xE0 hi\u1EC7u qu\u1EA3 hu\u1EA5n luy\u1EC7n"
  - id: rel_0001
    textList:
    - language: 0
      text: A crude wooden shield that provides basic defense
    - language: 1
      text: "Chi\u1EBFc khi\xEAn g\u1ED7 \u0111\u01A1n gi\u1EA3n, cung c\u1EA5p kh\u1EA3
        n\u0103ng ph\xF2ng th\u1EE7 c\u01A1 b\u1EA3n"
  - id: rel_0002
    textList:
    - language: 0
      text: "A beginner\u2019s bracelet that slightly boosts vitality for better
        survivability"
    - language: 1
      text: "T\u0103ng nh\u1EB9 sinh l\u1EF1c, gi\xFAp ch\u1ECBu \u0111\xF2n t\u1ED1t
        h\u01A1n"
  - id: rel_0003
    textList:
    - language: 0
      text: Heavy iron weights that increase strength but slow movement
    - language: 1
      text: "T\u0103ng s\u1EE9c m\u1EA1nh c\u01A1 b\u1EAFp nh\u01B0ng l\xE0m gi\u1EA3m
        t\u1ED1c \u0111\u1ED9 di chuy\u1EC3n"
  - id: rel_0004
    textList:
    - language: 0
      text: Lightweight boots that improve agility and attack fluidity
    - language: 1
      text: "\u0110\xF4i gi\xE0y nh\u1EB9 gi\xFAp di chuy\u1EC3n v\xE0 t\u1EA5n c\xF4ng
        linh ho\u1EA1t h\u01A1n"
  - id: rel_0005
    textList:
    - language: 0
      text: Enhances intelligence while sacrificing physical capability
    - language: 1
      text: "T\u0103ng tr\xED tu\u1EC7 nh\u01B0ng gi\u1EA3m hi\u1EC7u qu\u1EA3 th\u1EC3
        ch\u1EA5t"
  - id: rel_0006
    textList:
    - language: 0
      text: A sturdy bronze shield that trades speed for durability
    - language: 1
      text: "T\u0103ng ph\xF2ng th\u1EE7 \u0111\xE1ng k\u1EC3 nh\u01B0ng gi\u1EA3m
        t\u1ED1c \u0111\u1ED9"
  - id: rel_0007
    textList:
    - language: 0
      text: A radiant gem that enhances vitality and endurance
    - language: 1
      text: "Truy\u1EC1n th\xEAm s\u1EE9c s\u1ED1ng v\xE0 \u0111\u1ED9 b\u1EC1n cho
        ng\u01B0\u1EDDi \u0111eo"
  - id: rel_0008
    textList:
    - language: 0
      text: Boosts offensive power while neglecting defense
    - language: 1
      text: "T\u0103ng s\u1EE9c t\u1EA5n c\xF4ng m\u1EA1nh m\u1EBD nh\u01B0ng b\u1ECF
        qua ph\xF2ng ng\u1EF1"
  - id: rel_0009
    textList:
    - language: 0
      text: Offers massive protection at the cost of mobility
    - language: 1
      text: "B\u1EA3o v\u1EC7 c\u1EF1c cao nh\u01B0ng r\u1EA5t n\u1EB7ng v\xE0 c\u1ED3ng
        k\u1EC1nh"
  - id: rel_0010
    textList:
    - language: 0
      text: Sacrifices physical strength to enhance intelligence and speed
    - language: 1
      text: "Gi\u1EA3m th\u1EC3 ch\u1EA5t \u0111\u1EC3 t\u0103ng tr\xED tu\u1EC7
        v\xE0 t\u1ED1c \u0111\u1ED9"
  - id: rel_0011
    textList:
    - language: 0
      text: Helps sustain continuous action and skill usage
    - language: 1
      text: "Gi\xFAp duy tr\xEC nh\u1ECBp \u0111\u1ED9 chi\u1EBFn \u0111\u1EA5u li\xEAn
        t\u1EE5c"
  - id: rel_0012
    textList:
    - language: 0
      text: Grants balanced growth across all attributes
    - language: 1
      text: "T\u0103ng tr\u01B0\u1EDFng c\xE2n b\u1EB1ng t\u1EA5t c\u1EA3 ch\u1EC9
        s\u1ED1"
  - id: rel_0013
    textList:
    - language: 0
      text: Turns the wearer into an unyielding defensive wall
    - language: 1
      text: "Bi\u1EBFn ng\u01B0\u1EDDi \u0111eo th\xE0nh b\u1EE9c t\u01B0\u1EDDng
        ph\xF2ng th\u1EE7 v\u1EEFng ch\u1EAFc"
  - id: rel_0014
    textList:
    - language: 0
      text: Maximizes damage output at the cost of defense
    - language: 1
      text: "T\u1ED1i \u0111a h\xF3a s\xE1t th\u01B0\u01A1ng b\u1EB1ng c\xE1ch gi\u1EA3m
        ph\xF2ng th\u1EE7"
  - id: rel_0015
    textList:
    - language: 0
      text: Greatly enhances magic power while diminishing physical strength
    - language: 1
      text: "T\u0103ng m\u1EA1nh ma l\u1EF1c, l\xE0m suy y\u1EBFu th\u1EC3 ch\u1EA5t"
  - id: rel_0016
    textList:
    - language: 0
      text: Converts vitality into enduring defense
    - language: 1
      text: "Chuy\u1EC3n h\xF3a sinh l\u1EF1c th\xE0nh l\u1EDBp ph\xF2ng th\u1EE7
        b\u1EC1n v\u1EEFng"
  - id: rel_0017
    textList:
    - language: 0
      text: Greatly boosts attack power while ignoring incoming damage
    - language: 1
      text: "T\u0103ng s\u1EE9c t\u1EA5n c\xF4ng m\u1EA1nh m\u1EBD b\u1EA5t ch\u1EA5p
        ch\u1ECBu s\xE1t th\u01B0\u01A1ng"
  - id: rel_0018
    textList:
    - language: 0
      text: Sacrifices physical strength for exceptional agility
    - language: 1
      text: "Gi\u1EA3m th\u1EC3 ch\u1EA5t \u0111\u1EC3 \u0111\u1ED5i l\u1EA5y s\u1EF1
        nhanh nh\u1EB9n v\u01B0\u1EE3t tr\u1ED9i"
  - id: rel_0019
    textList:
    - language: 0
      text: Drains vitality to unleash devastating physical damage
    - language: 1
      text: "Hy sinh sinh l\u1EF1c \u0111\u1EC3 g\xE2y s\xE1t th\u01B0\u01A1ng v\u1EADt
        l\xFD c\u1EF1c l\u1EDBn"
  - id: rel_0020
    textList:
    - language: 0
      text: A symbol of supremacy that greatly boosts all stats
    - language: 1
      text: "T\u0103ng m\u1EA1nh to\xE0n b\u1ED9 ch\u1EC9 s\u1ED1"
  - id: rel_0021
    textList:
    - language: 0
      text: Negates most damage at the cost of offensive power
    - language: 1
      text: "G\u1EA7n nh\u01B0 mi\u1EC5n nhi\u1EC5m s\xE1t th\u01B0\u01A1ng, \u0111\xE1nh
        \u0111\u1ED5i kh\u1EA3 n\u0103ng t\u1EA5n c\xF4ng"
  - id: rel_0022
    textList:
    - language: 0
      text: Unlocks immense magical power by severing physical limits
    - language: 1
      text: "Gi\u1EA3i ph\xF3ng ma l\u1EF1c b\u1EB1ng c\xE1ch lo\u1EA1i b\u1ECF gi\u1EDBi
        h\u1EA1n th\u1EC3 ch\u1EA5t"
  - id: rel_0023
    textList:
    - language: 0
      text: Converts health and armor into devastating critical power
    - language: 1
      text: "Hy sinh m\xE1u v\xE0 gi\xE1p \u0111\u1EC3 t\u0103ng s\u1EE9c m\u1EA1nh
        b\u1EA1o k\xEDch"
  - id: rel_0024
    textList:
    - language: 0
      text: Warps time to grant speed beyond natural limits
    - language: 1
      text: "B\u1EBB cong th\u1EDDi gian, t\u0103ng t\u1ED1c \u0111\u1ED9 v\u01B0\u1EE3t
        gi\u1EDBi h\u1EA1n"
