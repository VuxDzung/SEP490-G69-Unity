%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01c2cf2a4b2c62142a7668242814b230, type: 3}
  m_Name: TextConfig.Tooltips
  m_EditorClassIdentifier: 
  category: Tooltips
  textDataList:
  - id: tt_btn_training
    textList:
    - language: 0
      text: Enhance your partner's stats through training sessions
    - language: 1
      text: "T\u0103ng c\u01B0\u1EDDng ch\u1EC9 s\u1ED1 c\u1EE7a linh th\xFA b\u1EB1ng
        nh\u1EEFng b\xE0i hu\u1EA5n luy\u1EC7n"
  - id: tt_btn_rest
    textList:
    - language: 0
      text: Rest to recover a certain amount of energy
    - language: 1
      text: "Ngh\u1EC9 ng\u01A1i \u0111\u1EC3 h\u1ED3i ph\u1EE5c l\u1EA1i l\u01B0\u1EE3ng
        n\u0103ng l\u01B0\u1EE3ng nh\u1EA5t \u0111\u1ECBnh"
  - id: tt_btn_deck
    textList:
    - language: 0
      text: View all the cards you have and edit your deck.
    - language: 1
      text: "Xem t\u1EA5t c\u1EA3 nh\u1EEFng l\xE1 b\xE0i \u0111ang c\xF3 v\xE0 ch\u1EC9nh
        s\u1EEDa b\u1ED9 b\xE0i"
  - id: tt_btn_inventory
    textList:
    - language: 0
      text: See all the items in your inventory
    - language: 1
      text: "Xem t\u1EA5t c\u1EA3 \u0111\u1ED3 trong t\xFAi"
  - id: tt_btn_tournament
    textList:
    - language: 0
      text: View the schedule of upcoming major and minor tournaments
    - language: 1
      text: "Xem l\u1ECBch c\u1EE7a c\xE1c gi\u1EA3i \u0111\u1EA5u l\u1EDBn nh\u1ECF
        s\u1EAFp t\u1EDBi"
  - id: tt_bar_vit
    textList:
    - language: 0
      text: Scale with the character's vitality
    - language: 1
      text: "T\u1EF7 l\u1EC7 v\u1EDBi sinh l\u1EF1c c\u1EE7a nh\xE2n v\u1EADt"
  - id: tt_bar_pow
    textList:
    - language: 0
      text: Scale with the character's strength
    - language: 1
      text: "T\u1EF7 l\u1EC7 v\u1EDBi s\u1EE9c m\u1EA1nh c\u1EE7a nh\xE2n v\u1EADt"
  - id: tt_bar_agi
    textList:
    - language: 0
      text: Scale with the character's speed
    - language: 1
      text: "T\u1EF7 l\u1EC7 v\u1EDBi t\u1ED1c \u0111\u1ED9 c\u1EE7a nh\xE2n v\u1EADt"
  - id: tt_bar_int
    textList:
    - language: 0
      text: Scale with the character's success rate
    - language: 1
      text: "T\u1EF7 l\u1EC7 v\u1EDBi kh\u1EA3 n\u0103ng th\xE0nh c\xF4ng c\u1EE7a
        nh\xE2n v\u1EADt"
  - id: tt_bar_sta
    textList:
    - language: 0
      text: Scale with the character's stamina
    - language: 1
      text: "T\u1EF7 l\u1EC7 v\u1EDBi \u0111\u1ED9 b\u1EC1n c\u1EE7a nh\xE2n v\u1EADt"
  - id: tt_bar_energy
    textList:
    - language: 0
      text: Energy required for each action
    - language: 1
      text: "N\u0103ng l\u01B0\u1EE3ng c\u1EA7n thi\u1EBFt cho t\u1EEBng h\xE0nh
        \u0111\u1ED9ng"
  - id: tt_bar_rp
    textList:
    - language: 0
      text: 'Reputation points: criteria for evaluating participation in tournaments'
    - language: 1
      text: "\u0110i\u1EC3m danh ti\u1EBFng: ti\xEAu ch\xED \u0111\xE1nh gi\xE1 \u0111\u1EC3
        tham gia c\xE1c gi\u1EA3i \u0111\u1EA5u"
  - id: tt_text_mood
    textList:
    - language: 0
      text: 'Mood: display the character''s current mood'
    - language: 1
      text: "T\xE2m tr\u1EA1ng: t\xE2m tr\u1EA1ng hi\u1EC7n t\u1EA1i c\u1EE7a nh\xE2n
        v\u1EADt"
