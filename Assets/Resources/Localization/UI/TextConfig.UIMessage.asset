%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01c2cf2a4b2c62142a7668242814b230, type: 3}
  m_Name: TextConfig.UIMessage
  m_EditorClassIdentifier: 
  category: UIMessage
  textDataList:
  - id: title_error
    textList:
    - language: 0
      text: Error
    - language: 1
      text: "L\u1ED7i"
  - id: title_noti
    textList:
    - language: 0
      text: Notification
    - language: 1
      text: "Th\xF4ng b\xE1o"
  - id: title_success
    textList:
    - language: 0
      text: Success
    - language: 1
      text: "Th\xE0nh c\xF4ng"
  - id: title_failed
    textList:
    - language: 0
      text: Failed
    - language: 1
      text: "Th\u1EA5t b\u1EA1i"
  - id: msg_internet_error
    textList:
    - language: 0
      text: No internet connection.
    - language: 1
      text: "Kh\xF4ng c\xF3 k\u1EBFt n\u1ED1i m\u1EA1ng."
  - id: msg_has_active_session
    textList:
    - language: 0
      text: There's an active training session. If you run a new game, the current
        session is deleted. Do you wish to continue?
    - language: 1
      text: "\u0110ang c\xF3 m\u1ED9t phi\xEAn hu\u1EA5n luy\u1EC7n ch\u01B0a ho\xE0n
        th\xE0nh. N\u1EBFu b\u1EA1n b\u1EAFt \u0111\u1EA7u hu\u1EA5n luy\u1EC7n m\u1ED9t
        nh\xE2n v\u1EADt m\u1EDBi, b\u1EA1n s\u1EBD m\u1EA5t d\u1EEF li\u1EC7u hu\u1EA5n
        luy\u1EC7n hi\u1EC7n t\u1EA1i. B\u1EA1n c\xF3 mu\u1ED1n ti\u1EBFp t\u1EE5c?"
  - id: msg_fail_connect_be
    textList:
    - language: 0
      text: Failed to connect to the server. Check your internet connection.
    - language: 1
      text: "Th\u1EA5t b\u1EA1i khi k\u1EBFt n\u1ED1i v\u1EDBi m\xE1y ch\u1EE7. H\xE3y
        ki\u1EC3m tra k\u1EBFt n\u1ED1i m\u1EA1ng c\u1EE7a b\u1EA1n."
  - id: msg_firebase_connect_fail
    textList:
    - language: 0
      text: Failed to connect to Furebase. Check your internet connection.
    - language: 1
      text: "Th\u1EA5t b\u1EA1i khi k\u1EBFt n\u1ED1i v\u1EDBi Firebase. Xin h\xE3y
        ki\u1EC3m tra l\u1EA1i k\u1EBFt n\u1ED1i c\u1EE7a b\u1EA1n."
  - id: msg_reset_pw_email_sent
    textList:
    - language: 0
      text: A reset password notification has been sent to your email. Please check
        your email.
    - language: 1
      text: "M\u1ED9t th\xF4ng b\xE1o c\xE0i l\u1EA1i m\u1EADt kh\u1EA9u \u0111\xE3
        \u0111\u01B0\u1EE3c g\u1EEDi t\u1EDBi email c\u1EE7a b\u1EA1n. H\xE3y ki\u1EC3m
        tra email."
  - id: msg_cancel_reset_pw
    textList:
    - language: 0
      text: Reset password process has been cancelled.
    - language: 1
      text: "Qu\xE1 tr\xECnh \u0111\u1EB7t l\u1EA1i m\u1EADt kh\u1EA9u \u0111\xE3
        b\u1ECB h\u1EE7y"
  - id: msg_error_reset_pw
    textList:
    - language: 0
      text: Failed to reset password
    - language: 1
      text: "Th\u1EA5t b\u1EA1i khi \u0111\u1EB7t l\u1EA1i m\u1EADt kh\u1EA9u."
  - id: msg_reset_pw_success
    textList:
    - language: 0
      text: Reset password successfully. Please go back to login.
    - language: 1
      text: "\u0110\xE3 \u0111\u1EB7t l\u1EA1i m\u1EADt kh\u1EA9u th\xE0nh c\xF4ng.
        Xin h\xE3y quay l\u1EA1i trang \u0111\u0103ng nh\u1EADp."
  - id: msg_welcome
    textList:
    - language: 0
      text: Welcome
    - language: 1
      text: "Ch\xE0o m\u1EEBng"
  - id: msg_welcome_back
    textList:
    - language: 0
      text: Welcome back
    - language: 1
      text: "Ch\xE0o m\u1EEBng tr\u1EDF l\u1EA1i"
  - id: msg_new_week_start
    textList:
    - language: 0
      text: New week started...
    - language: 1
      text: "B\u1EAFt \u0111\u1EA7u tu\u1EA7n m\u1EDBi..."
  - id: msg_week
    textList:
    - language: 0
      text: Week
    - language: 1
      text: "Tu\u1EA7n"
  - id: msg_year
    textList:
    - language: 0
      text: Year
    - language: 1
      text: "N\u0103m"
  - id: title_victory
    textList:
    - language: 0
      text: VICTORY
    - language: 1
      text: "CHI\u1EBEN TH\u1EAENG"
  - id: title_defeat
    textList:
    - language: 0
      text: DEFEAT
    - language: 1
      text: "\u0110\xC1NH B\u1EA0I"
  - id: msg_victory
    textList:
    - language: 0
      text: You are victorious
    - language: 1
      text: "B\u1EA1n \u0111\xE3 chi\u1EBFn th\u1EAFng"
  - id: msg_defeat
    textList:
    - language: 0
      text: You have been defeated.
    - language: 1
      text: "B\u1EA1n \u0111\xE3 b\u1ECB \u0111\xE1nh b\u1EA1i"
  - id: msg_relic
    textList:
    - language: 0
      text: Relic
    - language: 1
      text: "Di v\u1EADt"
  - id: msg_usable
    textList:
    - language: 0
      text: Usable
    - language: 1
      text: "\u0110\u1ED3 ti\xEAu hao"
  - id: msg_easy
    textList:
    - language: 0
      text: Easy
    - language: 1
      text: "D\u1EC5"
  - id: msg_medium
    textList:
    - language: 0
      text: Medium
    - language: 1
      text: "Trung b\xECnh"
  - id: msg_hard
    textList:
    - language: 0
      text: Hard
    - language: 1
      text: "Kh\xF3"
  - id: msg_encounter
    textList:
    - language: 0
      text: Encounter
    - language: 1
      text: "Ch\u1EA1m tr\xE1n"
  - id: msg_treasure
    textList:
    - language: 0
      text: Treasure
    - language: 1
      text: "Kho b\xE1u"
  - id: msg_boss
    textList:
    - language: 0
      text: Boss
    - language: 1
      text: "Tr\xF9m"
  - id: msg_combat
    textList:
    - language: 0
      text: Combat
    - language: 1
      text: "Chi\u1EBFn \u0111\u1EA5u"
  - id: msg_upgrade_success
    textList:
    - language: 0
      text: Upgrade facility sucessfully
    - language: 1
      text: "N\xE2ng c\u1EA5p b\xE0i t\u1EADp th\xE0nh c\xF4ng"
  - id: msg_upgrade_max_level
    textList:
    - language: 0
      text: You have reached the max level of the facility
    - language: 1
      text: "B\u1EA1n \u0111\xE3 \u0111\u1EA1t m\u1EE9c cao nh\u1EA5t c\u1EE7a b\xE0i
        t\u1EADp n\xE0y."
  - id: msg_not_enough_gold
    textList:
    - language: 0
      text: You don't have enough money to perform this action
    - language: 1
      text: "B\u1EA1n kh\xF4ng c\xF3 \u0111\u1EE7 ti\u1EC1n \u0111\u1EC3 th\u1EF1c
        hi\u1EC7n h\xE0nh \u0111\u1ED9ng n\xE0y."
  - id: msg_rank_too_low
    textList:
    - language: 0
      text: Your Reputation Points (RP) is too low to perform this action
    - language: 1
      text: "\u0110i\u1EC3m Danh V\u1ECDng (RP) c\u1EE7a b\u1EA1n kh\xF4ng \u0111\u1EE7
        \u0111\u1EC3 th\u1EF1c hi\u1EC7n h\xE0nh \u0111\u1ED9ng n\xE0y"
  - id: msg_upgrade_error
    textList:
    - language: 0
      text: There's an error while upgrading the facility. Please contact to the
        developer to handle this issue.
    - language: 1
      text: "B\u1EA1n \u0111ang g\u1EB7p m\u1ED9t l\u1ED7i khi n\xE2ng c\u1EA5p b\xE0i
        t\u1EADp. H\xE3y li\xEAn h\u1EC7 v\u1EDBi nh\xE0 ph\xE1t tri\u1EC1n \u0111\u1EC3
        gi\u1EA3i quy\u1EBFt v\u1EA5n \u0111\u1EC1 n\xE0y."
  - id: msg_auto_or_manual_battle
    textList:
    - language: 0
      text: Do you want to give direct order to your Spirit Animal or let it show
        its own strength?
    - language: 1
      text: "B\u1EA1n mu\u1ED1n t\u1EF1 tay \u0111i\u1EC1u khi\u1EC3n linh th\xFA
        hay \u0111\u1EC3 linh th\xFA c\u1EE7a b\u1EA1n t\u1EF1 th\u1EC3 hi\u1EC7n
        s\u1EE9c m\u1EA1nh c\u1EE7a m\xECnh?"
  - id: msg_auto_combat
    textList:
    - language: 0
      text: Auto combat
    - language: 1
      text: "T\u1EF1 \u0111\u1ED9ng chi\u1EBFn \u0111\u1EA5u"
  - id: msg_manual_combat
    textList:
    - language: 0
      text: Manual combat
    - language: 1
      text: "Chi\u1EBFn \u0111\u1EA5u th\u1EE7 c\xF4ng"
  - id: msg_confirm
    textList:
    - language: 0
      text: Confirm
    - language: 1
      text: "X\xE1c nh\u1EADn"
  - id: msg_cancel
    textList:
    - language: 0
      text: Cancel
    - language: 1
      text: "H\u1EE7y"
  - id: msg_lose_checkpoint_tournament
    textList:
    - language: 0
      text: No
    - language: 1
      text: "Kh\xF4ng"
  - id: title_game_over
    textList:
    - language: 0
      text: Game Over
    - language: 1
      text: "Thua cu\u1ED9c"
  - id: msg_game_over
    textList:
    - language: 0
      text: You've failed to prove your yourself to your old man.
    - language: 1
      text: "B\u1EA1n \u0111\xE3 th\xE0nh c\xF4ng trong vi\u1EC7c l\xE0m \xF4ng b\xF4
        c\u1EE7a b\u1EA1n th\u1EA5t v\u1ECDng"
  - id: msg_end
    textList:
    - language: 0
      text: End
    - language: 1
      text: "K\u1EBFt th\xFAc"
  - id: msg_delete_session_db_error
    textList:
    - language: 0
      text: There's a system error which stop the delete old session data. Please
        contact to the developer
    - language: 1
      text: "C\xF3 l\u1ED7i h\u1EC7 th\u1ED1ng khi\u1EBFn vi\u1EC7c x\xF3a d\u1EEF
        li\u1EC7u phi\xEAn c\u0169 b\u1ECB d\u1EEBng l\u1EA1i. Vui l\xF2ng li\xEAn
        h\u1EC7 v\u1EDBi nh\xE0 ph\xE1t tri\u1EC3n."
